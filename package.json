{
  "name": "@perryfinn/ai-commit-cli",
  "version": "0.0.2",
  "description": "一个利用 AI 服务（OpenAI、Dify 等）自动生成遵循指定标准的提交信息并处理提交过程的命令行工具。用 AI 消灭低价值 commit。🥳",
  "keywords": [
    "AI",
    "git",
    "commit",
    "CLI",
    "openai",
    "Dify"
  ],
  "homepage": "https://github.com/PerryFinn/ai-commit-cli#readme",
  "bugs": {
    "url": "https://github.com/PerryFinn/ai-commit-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PerryFinn/ai-commit-cli.git"
  },
  "license": "MIT",
  "author": "PerryFinn <perryfinn@163.com>",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aigcm": "./dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "build:changeset": "ENABLE_CHANGESET_BUILD=true tsdown",
    "check:exports": "attw --pack . --profile=node16",
    "ci": "biome ci && bun run typecheck && bun run test && bun run build && bun run check:exports",
    "debug": "bun run build && AIGCM_LLM_PROVIDER=OPEN_AI node ./dist/index.cjs config set AIGCM_MODEL_ID=gpt-4o AIGCM_ONE_LINE_COMMIT=true AIGCM_DEMOTEST=true AIGCM_MAX_TOKEN_INPUT=1024 && node ./dist/index.cjs config ls",
    "lint": "biome check . --no-errors-on-unmatched",
    "lint:fix": "biome check --write . --no-errors-on-unmatched",
    "precommit": "biome ci && bun run typecheck",
    "prepare": "husky",
    "prepublishOnly": "bun run ci",
    "release": "changeset publish",
    "release:version": "changeset version",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "**/package.json": [
      "sort-package-json",
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{js,jsx,ts,tsx}": [
      "biome check --write --no-errors-on-unmatched",
      "vitest related --run"
    ],
    "*.{css,json,jsonc,graphql,gql}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@inquirer/prompts": "^7.8.6",
    "chalk": "^5.6.2",
    "conf": "^15.0.2",
    "execa": "^9.6.0",
    "mri": "^1.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "2.2.5",
    "@changesets/cli": "^2.29.7",
    "@changesets/types": "^6.1.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/types": "^20.0.0",
    "@types/bun": "^1.2.23",
    "@types/node": "22.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "sort-package-json": "^3.4.0",
    "tsdown": "^0.15.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=22"
  },
  "volta": {
    "node": "22.19.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
